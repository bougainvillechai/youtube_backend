<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form p-10 text-white">
            <form action="/create" method="POST">
                <input class="block w-full rounded-lg outline-none px-3 py-5 bg-zinc-800" type="text" placeholder="Title goes here" name="title">
                <textarea class="block w-full  rounded-lg outline-none mt-2 px-3 py-5 bg-zinc-800 resize-none" placeholder="Task details..." id="" name="details"></textarea>
                <input class="mt-2 bg-blue-600 px-4 py-2 rounded-lg" type="submit" value="Create Task">
            </form>
        </div>
        <div class="tasks p-10 text-white flex gap-3 flex-wrap">
            <% if (files.length > 0){ %>
                <% files.forEach(file => { %>
                    <div class="task bg-zinc-800 p-5 rounded-lg w-72 relative group">
                        <h2 class="text-2xl tracking-tighter font-bold"><%= file.replace('.txt', '') %></h2>
                        <a class="text-blue-500 inline-block mt-3" href="/read/<%= file %>">Read More...</a>
                        <a href="/delete/<%= file %>" class="absolute top-3 right-3 text-zinc-700 group-hover:text-red-500 transition-all duration-300">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                        </a>
                    </div>
                <% }); %>
            <% } else { %>
                <h3 class="text-zinc-600">No Tasks</h3>
            <% } %>
        </div>
    </div>
</body>
</html>